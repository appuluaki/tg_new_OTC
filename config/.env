# ── Olymptrade Credentials ──────────────────────────────────────────
OLYMPTRADE_EMAIL=mrakillraja.official@gmail.com
OLYMPTRADE_PASSWORD=jANUAKILL@123

# ── Trading Settings ────────────────────────────────────────────────
# NOTE: Keep asset in code-friendly format (no spaces/slashes) to match
# strategy pair names (e.g. EURUSD-OTC). The orchestrator uses internal
# `FOREX_PAIRS` so this value is mainly informative for other scripts.
ASSET=EURUSD-OTC
TRADE_AMOUNT=1000
TRADE_MODE=ftt              # ftt | forex | both
FTT_DURATION=60             # FTT trade duration in seconds (e.g. 5, 15, 30, 60, 120, 300)
# Reduce poll interval so the system re-checks more often when searching
# for valid setups (shorter = more frequent scans). Default was 60s.
POLL_INTERVAL_SECONDS=15

# ── Risk Management ─────────────────────────────────────────────────
# Lower the confidence threshold temporarily to increase trade frequency.
# Monitor performance and revert after observation period.
CONFIDENCE_THRESHOLD=0.45    # Min confidence (0.0 to 1.0) to trade
MAX_DAILY_TRADES=2000       # Max trades before stopping for the day
MAX_DAILY_LOSS_USD=10000    # Max USD loss before stopping for the day
STOP_LOSS_PCT=0.02          # Forex stop loss percentage (e.g. 0.02 = 2%)
LOG_DATE_FORMAT=%Y%m%d      # Date format used for daily archive filenames
LOG_ARCHIVE_DIR=logs/archive # Where rotated logs are moved each day
JOURNAL_ARCHIVE_DIR=logs/archive # Where rotated trade journals are stored
RESET_TODAY_LOGS_ON_STARTUP=true # Set true to clear today's journal rows and reset risk on startup
RL_USE_IN_LIVE_TRADING=false # Set true to let RL recommendations affect live trade decisions

# ── Machine Learning Model ──────────────────────────────────────────
MODEL_TYPE=rl                # random_forest | lstm | ensemble | rl
LOOKBACK_CANDLES=60          # Number of candles used for LSTM input
CANDLE_TIMEFRAME=M1          # M1, M5, M15, M30, H1

# ── Browser Options ─────────────────────────────────────────────────
HEADLESS=false               # Set to false to watch the browser UI

# ── Trading & Risk Tuning ───────────────────────────────────────────────
TARGET_PROFIT_PER_TRADE_USD=100
MAX_TRADE_LOSS_USD=300
# TRADE_AMOUNT defined above

# ── Telegram Alerts ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8709590457:AAFnAtABS5-ep1A1nT-3GIoHoC9G6qwqta8
TELEGRAM_CHAT_ID=-1001234567890
LOGIN_WAIT_SECONDS=300     # Seconds to wait for manual login detection
