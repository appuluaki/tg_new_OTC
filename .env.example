# Example environment variables for Railway deployment
# Copy this file to .env and update values before deploying.

# App settings
APP_ENV=production
LOG_LEVEL=INFO

# Trading / bot credentials
TELEGRAM_BOT_TOKEN=your-telegram-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
API_KEY=your-api-key
API_SECRET=your-api-secret

# Data provider and strategy config
DATA_PROVIDER_URL=https://example.com/data
EXCHANGE=BTCUSD
TIMEFRAME=M1

# Playwright / browser config
PLAYWRIGHT_BROWSER=chromium

# Optional: debugging and monitoring
SENTRY_DSN=

# Disable browser UI in container
HEADLESS=true
